{
  "name": "@forgeax/agent-host",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "description": "forgeax ring-0 sidecar — kernel process supervision + IPC control plane (R3 阶段1脊梁). Self-contained leaf: zero @forgeax/* deps, independently cloneable.",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/types.js",
    "./serve": "./dist/main.js"
  },
  "bin": {
    "forgeax-agent-host": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build.mjs",
    "pack:tgz": "npm pack",
    "start": "bun src/main.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint:boundaries": "depcruise --config .dependency-cruiser.cjs src"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.0.0",
    "dependency-cruiser": "^17.4.3",
    "typescript": "^5.6.3"
  }
}
